<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ServeLink"
            android:textSize="18dp"
            android:textColor="@color/black"/>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="300dp"
        android:layout_marginTop="10dp"
        android:layout_height="300dp"
        app:cardCornerRadius="20dp">

        <ImageView
            android:id="@+id/illustrationImage"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:src="@drawable/ima1"
            android:layout_marginBottom="40dp"
            android:scaleType="centerCrop" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_marginTop="20dp"
        android:id="@+id/textTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textSize="20sp"
        android:text="Affordable Reliable Services"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:text="Quality affordable services for all, from your basic home requirements to corporate service. Servelink has you covered."
        android:textColor="@color/text_grey" />
</LinearLayout>
